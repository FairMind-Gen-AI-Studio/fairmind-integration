{
  "name": "fairmind-integration",
  "version": "3.0.0",
  "contextFileName": "GEMINI.md",
  "mcpServers": {
    "fairmind": {
      "url": "${FAIRMIND_MCP_URL}",
      "type": "http",
      "headers": {
        "Authorization": "Bearer ${FAIRMIND_API_KEY}"
      },
      "timeout": 30000
    }
  },
  "excludeTools": [],
  "settings": [
    {
      "name": "FairMind API Key",
      "description": "API key for FairMind MCP server authentication",
      "envVar": "FAIRMIND_API_KEY"
    },
    {
      "name": "FairMind MCP URL",
      "description": "FairMind MCP server endpoint URL",
      "envVar": "FAIRMIND_MCP_URL"
    }
  ]
}
